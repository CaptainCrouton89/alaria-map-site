# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

public/tiles/**/*.png
public/tiles/**/*.webp

# Large source image (616MB) - tiles are hosted on R2
public/Alaria.png
data/backups/

# Claude scheduler runtime
.claude/scheduled_tasks.lock

# local map-shot renders / scratch
tmp/
# image-gen scratch: transient banner renders + pilot prompt lists
.tmp-*
tmp-*.json

# Sisyphus
.sisyphus

# crtr local tooling state
.crouter/

# Cloudflare Wrangler local state cache
.wrangler/

# transient codex build lock (multi-session build serialization)
.codex-build.lock/

# Python bytecode (codex audit scripts)
__pycache__/
*.pyc
